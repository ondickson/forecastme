# =============================================================================
# ForecastMe Local Infrastructure
# =============================================================================
# Copy this file to .env before starting Docker Compose:
#
# Copy-Item .env.example .env
#
# Never commit the real .env file.

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_DB=forecastme
POSTGRES_USER=forecastme
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# MinIO
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=forecastme
MINIO_ROOT_PASSWORD=change_this_minio_password
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# -----------------------------------------------------------------------------
# pgAdmin
# -----------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@forecastme.com
PGADMIN_DEFAULT_PASSWORD=change_this_pgadmin_password
PGADMIN_PORT=5050