{
  "name": "forecastme",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint && pnpm python:lint",
    "lint:fix": "turbo run lint:fix && pnpm python:lint:fix",
    "format": "prettier --write . && pnpm python:format",
    "format:check": "prettier --check . && pnpm python:format:check",
    "typecheck": "turbo run typecheck && pnpm python:typecheck",
    "test": "turbo run test && pnpm python:test",
    "python:lint": "node scripts/python-runner.cjs -m ruff check services/prediction-service",
    "python:lint:fix": "node scripts/python-runner.cjs -m ruff check services/prediction-service --fix",
    "python:format": "node scripts/python-runner.cjs -m ruff format services/prediction-service",
    "python:format:check": "node scripts/python-runner.cjs -m ruff format services/prediction-service --check",
    "python:typecheck": "node scripts/python-runner.cjs -m mypy services/prediction-service/app",
    "python:test": "node scripts/python-runner.cjs -m pytest services/prediction-service"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
