{
  "name": "@forecastme/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "lint:fix": "node -e \"console.log('No automatic lint fixes configured for contracts')\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No contracts tests configured yet')\"",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  }
}
